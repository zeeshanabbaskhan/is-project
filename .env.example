# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=production

# Base URL (your deployed domain)
BASE_URL=http://localhost:5000

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/secure-file-sharing

# JWT Secret (use a strong random string - generate with: openssl rand -hex 32)
JWT_SECRET=

# RSA Keys for Vercel (required for production serverless - generate once and keep stable)
# Generate with: openssl genrsa 2048 (private) and openssl rsa -pubout (public)
# Paste PEM contents with \n for newlines, or use Vercel multiline env vars
SERVER_RSA_PRIVATE_KEY=
SERVER_RSA_PUBLIC_KEY=

# 2FA Configuration
TWO_FACTOR_APP_NAME=SecureFileSharing

# Email Configuration (for password reset, notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
